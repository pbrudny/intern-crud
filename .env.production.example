# Production Environment Variables for Coolify
# Copy these to your Coolify environment variables section

# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string

# Database Configuration
DATABASE_URL=sqlite:///instance/intern_crud.db

# Flask Environment
FLASK_ENV=production

# File Upload Configuration
UPLOAD_FOLDER=/app/uploads/resumes
MAX_CONTENT_LENGTH=2097152

# Optional: If using PostgreSQL instead of SQLite
# DATABASE_URL=postgresql://user:password@host:5432/dbname

